{
  "name": "open-browser-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "dev:web": "bun run --filter @open-browser/web dev",
    "build:web": "bun run --filter @open-browser/web build",
    "dev:worker": "bun run --filter @open-browser/worker dev",
    "start:worker": "bun run --filter @open-browser/worker start"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.2.0",
    "postgres": "^3.4.8",
    "typescript": "^5.8.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
