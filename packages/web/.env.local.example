# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption (32-byte hex string for AES-256-GCM)
ENCRYPTION_KEY=your-64-char-hex-string

# OAuth - Google (for user login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - AI Providers (for API access)
OPENAI_OAUTH_CLIENT_ID=your-openai-client-id
OPENAI_OAUTH_CLIENT_SECRET=your-openai-client-secret
ANTHROPIC_OAUTH_CLIENT_ID=your-anthropic-client-id
ANTHROPIC_OAUTH_CLIENT_SECRET=your-anthropic-client-secret
GOOGLE_AI_OAUTH_CLIENT_ID=your-google-ai-client-id
GOOGLE_AI_OAUTH_CLIENT_SECRET=your-google-ai-client-secret

# Cloud Run Worker
WORKER_URL=https://your-worker.run.app

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
